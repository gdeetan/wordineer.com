# Cloudflare Pages _headers — controls caching and compression

# Fonts: cache for 1 year (content-hashed filenames never change)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# words.json: cache for 7 days, serve stale for 1 day while revalidating
/data/words.json
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  Content-Type: application/json; charset=utf-8
  Vary: Accept-Encoding

# names.json: cache for 7 days, serve stale for 1 day while revalidating
/data/names.json
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  Content-Type: application/json; charset=utf-8
  Vary: Accept-Encoding

# Scripts: cache for 1 year — bump ?v= param in HTML when files change
/scripts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS: cache for 1 year — bump ?v= param in HTML when file changes
/styles/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages: short cache so updates land quickly
/*.html
  Cache-Control: public, max-age=300, stale-while-revalidate=60

/
  Cache-Control: public, max-age=300, stale-while-revalidate=60
