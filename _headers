# Netlify _headers — controls caching and compression

# Fonts: cache for 1 year (content-hashed filenames never change)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# words.json: cache for 7 days, serve stale for 1 day while revalidating
/data/words.json
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  Content-Type: application/json; charset=utf-8
  Vary: Accept-Encoding

# tool-engine.js: cache for 1 day
/scripts/tool-engine.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# CSS: cache for 1 day
/styles/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# HTML pages: short cache so updates land quickly
/*.html
  Cache-Control: public, max-age=300, stale-while-revalidate=60

/
  Cache-Control: public, max-age=300, stale-while-revalidate=60
